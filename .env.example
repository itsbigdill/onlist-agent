# Qwen / DashScope (required) — get a key at Alibaba Cloud Model Studio
DASHSCOPE_API_KEY=sk-...

# Optional overrides
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_TEXT_MODEL=qwen3.7-max
# QWEN_VISION_MODEL=qwen3.7-plus
# QWEN_FLASH_MODEL=qwen3.6-flash

# Live mode (optional): run the same agent against onlist.ai
# TARGET=onlist
# ONLIST_USER=yourusername
# ONLIST_TOKEN=paste from onlist app → Settings → Connect your AI
